\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Schematic illustration of the computation of the removal probability $P_{R}$ for a representative molecule (green). Left: a portion of the backbone where each rectangle represents a molecule (drawn with five segments for clarity). The green molecule intersects multiple cross-sections; for each intersected cross-section $i$, the local stress is $\sigma (i)=F/N(i)$ (right; example with $N(i)=9$, giving $\sigma (i)=F/9$).}}{10}{figure.5}\protected@file@percent }
\newlabel{fig_5}{{5}{10}{Schematic illustration of the computation of the removal probability $P_{R}$ for a representative molecule (green). Left: a portion of the backbone where each rectangle represents a molecule (drawn with five segments for clarity). The green molecule intersects multiple cross-sections; for each intersected cross-section $i$, the local stress is $\sigma (i)=F/N(i)$ (right; example with $N(i)=9$, giving $\sigma (i)=F/9$)}{figure.5}{}}
